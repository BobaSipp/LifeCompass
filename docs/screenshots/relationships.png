  <text x="432" y="222" font-family="Arial, sans-serif" font-size="16" fill="#3b82f6" text-anchor="middle" font-weight="bold">T</text>
  <text x="432" y="265" font-family="Arial, sans-serif" font-size="15" fill="#111827" text-anchor="middle" font-weight="bold">Thomas</text>
