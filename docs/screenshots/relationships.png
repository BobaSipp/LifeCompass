  <text x="648" y="378" font-family="Arial, sans-serif" font-size="11" fill="#10b981" text-anchor="middle">Log interaction</text>

  <!-- Card 3: Emma -->
  <rect x="864" y="155" width="275" height="260" rx="12" fill="#ffffff" filter="url(#shadow2)"/>
  <circle cx="724" cy="215" r="32" fill="#fef3c7"/>
  <text x="724" y="222" font-family="Arial, sans-serif" font-size="16" fill="#f59e0b" text-anchor="middle" font-weight="bold">E</text>
