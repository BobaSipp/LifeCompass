<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="800" viewBox="0 0 1200 800">
  <defs>
    <filter id="shadow1"><feDropShadow dx="0" dy="1" stdDeviation="2" flood-opacity="0.05"/></filter>
    <filter id="shadow2"><feDropShadow dx="0" dy="2" stdDeviation="4" flood-opacity="0.08"/></filter>
    <filter id="glowGreen"><feDropShadow dx="0" dy="0" stdDeviation="3" flood-color="#10b981" flood-opacity="0.4"/></filter>
  </defs>

  <rect width="1200" height="800" fill="#f1f5f9"/>

  <!-- Browser Chrome -->
  <rect x="0" y="0" width="1200" height="36" fill="#e2e8f0"/>
  <rect x="0" y="36" width="1200" height="1" fill="#cbd5e1"/>
  <circle cx="16" cy="18" r="5" fill="#ef4444"/>
  <circle cx="30" cy="18" r="5" fill="#f59e0b"/>
  <circle cx="44" cy="18" r="5" fill="#10b981"/>
  <rect x="120" y="10" width="300" height="16" rx="8" fill="#cbd5e1"/>
  <text x="270" y="22" font-family="Arial, sans-serif" font-size="9" fill="#64748b" text-anchor="middle">localhost:3000/trading</text>

  <!-- Sidebar -->
  <rect x="0" y="37" width="256" height="763" fill="#1a1a2e"/>
  <circle cx="128" cy="85" r="28" fill="#e94560" opacity="0.15"/>
  <circle cx="128" cy="85" r="24" fill="#1a1a2e" stroke="#e94560" stroke-width="2"/>
  <text x="128" y="91" font-family="Arial, sans-serif" font-size="18" fill="#e94560" text-anchor="middle" font-weight="bold">RS</text>
  <text x="128" y="130" font-family="Arial, sans-serif" font-size="14" fill="#ffffff" text-anchor="middle" font-weight="bold">Remco Stroop</text>
  <text x="128" y="148" font-family="Arial, sans-serif" font-size="9" fill="#e94560" text-anchor="middle" letter-spacing="1">PROGRESS TO SUCCESS</text>
  <line x1="40" y1="160" x2="216" y2="160" stroke="#ffffff" stroke-opacity="0.08"/>

  <g font-family="Arial, sans-serif" font-size="13" fill="#a0aec0">
    <text x="48" y="201">Dashboard</text>
    <text x="48" y="247">Daily Log</text>
    <text x="48" y="293">Life in Weeks</text>
    <text x="48" y="339">Finances</text>
    <!-- Trading - Active -->
    <rect x="12" y="360" width="232" height="36" rx="6" fill="#e94560" opacity="0.15"/>
    <text x="48" y="383" fill="#e94560" font-weight="bold">Trading</text>
    <text x="48" y="429">Business</text>
    <text x="48" y="475">Growth</text>
    <text x="48" y="521">Mental</text>
    <text x="48" y="567">Relationships</text>
    <text x="48" y="613">Books</text>
  </g>

  <g>
    <rect x="28" y="191" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="237" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="283" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="329" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="373" width="12" height="12" rx="3" fill="#e94560"/>
    <rect x="28" y="419" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="465" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="511" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="557" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="603" width="12" height="12" rx="3" fill="#a0aec0"/>
  </g>

  <!-- Main content -->
  <rect x="256" y="37" width="944" height="763" fill="#f8fafc"/>

  <!-- PageHeader -->
  <rect x="256" y="37" width="944" height="90" fill="#ffffff" filter="url(#shadow1)"/>
  <rect x="280" y="55" width="64" height="18" rx="9" fill="#e94560" opacity="0.1"/>
  <text x="312" y="68" font-family="Arial, sans-serif" font-size="10" fill="#e94560" text-anchor="middle" font-weight="bold">MARKETS</text>
  <text x="280" y="100" font-family="Arial, sans-serif" font-size="22" fill="#111827" font-weight="bold">Trading Desk</text>
  <text x="280" y="118" font-family="Arial, sans-serif" font-size="13" fill="#6b7280">Live prices, P&amp;L and trade journal. Stay on top of your game.</text>
  <!-- LIVE badge -->
  <rect x="1080" y="68" width="50" height="20" rx="10" fill="#10b981" opacity="0.15"/>
  <text x="1105" y="83" font-family="Arial, sans-serif" font-size="10" fill="#10b981" text-anchor="middle" font-weight="bold" filter="url(#glowGreen)">● LIVE</text>

  <!-- 4 Summary Cards -->
  <rect x="280" y="155" width="205" height="85" rx="10" fill="#ffffff" filter="url(#shadow2)"/>
  <text x="300" y="178" font-family="Arial, sans-serif" font-size="12" fill="#6b7280">Realized P&amp;L</text>
  <text x="300" y="210" font-family="Arial, sans-serif" font-size="20" fill="#10b981" font-weight="bold">+€3,420</text>

  <rect x="500" y="155" width="205" height="85" rx="10" fill="#ffffff" filter="url(#shadow2)"/>
  <text x="520" y="178" font-family="Arial, sans-serif" font-size="12" fill="#6b7280">Win Rate</text>
  <text x="520" y="205" font-family="Arial, sans-serif" font-size="20" fill="#111827" font-weight="bold">68%</text>
  <text x="520" y="225" font-family="Arial, sans-serif" font-size="10" fill="#6b7280">32 closed trades</text>

  <rect x="720" y="155" width="205" height="85" rx="10" fill="#ffffff" filter="url(#shadow2)"/>
  <text x="740" y="178" font-family="Arial, sans-serif" font-size="12" fill="#6b7280">Open Positions</text>
  <text x="740" y="210" font-family="Arial, sans-serif" font-size="20" fill="#111827" font-weight="bold">3</text>

  <rect x="940" y="155" width="205" height="85" rx="10" fill="#ffffff" filter="url(#shadow2)"/>
  <text x="960" y="178" font-family="Arial, sans-serif" font-size="12" fill="#6b7280">Best / Worst</text>
  <text x="960" y="205" font-family="Arial, sans-serif" font-size="18" fill="#10b981" font-weight="bold">+€2,100</text>
  <text x="960" y="225" font-family="Arial, sans-serif" font-size="13" fill="#ef4444">-€450</text>

  <!-- Watchlist section -->
  <rect x="280" y="260" width="440" height="220" rx="10" fill="#ffffff" filter="url(#shadow2)"/>
  <text x="300" y="285" font-family="Arial, sans-serif" font-size="16" fill="#111827" font-weight="bold">Watchlist</text>

  <!-- Symbol cards grid -->
  <!-- BTC -->
  <rect x="300" y="298" width="125" height="70" rx="8" fill="#f8fafc" stroke="#e5e7eb" stroke-width="1"/>
  <rect x="310" y="308" width="20" height="20" rx="5" fill="#f59e0b" opacity="0.2"/>
  <text x="320" y="323" font-family="Arial, sans-serif" font-size="10" fill="#f59e0b" text-anchor="middle">₿</text>
  <text x="340" y="323" font-family="Arial, sans-serif" font-size="13" fill="#111827" font-weight="bold">BTC</text>
  <text x="300" y="345" font-family="Arial, sans-serif" font-size="12" fill="#111827">$58,432</text>
  <text x="395" y="345" font-family="Arial, sans-serif" font-size="11" fill="#10b981" text-anchor="end">+2.1%</text>

  <!-- ETH -->
  <rect x="435" y="298" width="125" height="70" rx="8" fill="#f8fafc" stroke="#e5e7eb" stroke-width="1"/>
  <rect x="445" y="308" width="20" height="20" rx="5" fill="#3b82f6" opacity="0.2"/>
  <text x="455" y="323" font-family="Arial, sans-serif" font-size="10" fill="#3b82f6" text-anchor="middle">Ξ</text>
  <text x="475" y="323" font-family="Arial, sans-serif" font-size="13" fill="#111827" font-weight="bold">ETH</text>
  <text x="435" y="345" font-family="Arial, sans-serif" font-size="12" fill="#111827">$3,124</text>
  <text x="530" y="345" font-family="Arial, sans-serif" font-size="11" fill="#ef4444" text-anchor="end">-0.8%</text>

  <!-- AAPL -->
  <rect x="570" y="298" width="125" height="70" rx="8" fill="#f8fafc" stroke="#e5e7eb" stroke-width="1"/>
  <rect x="580" y="308" width="20" height="20" rx="5" fill="#6b7280" opacity="0.2"/>
  <text x="590" y="323" font-family="Arial, sans-serif" font-size="10" fill="#6b7280" text-anchor="middle">A</text>
  <text x="610" y="323" font-family="Arial, sans-serif" font-size="13" fill="#111827" font-weight="bold">AAPL</text>
  <text x="570" y="345" font-family="Arial, sans-serif" font-size="12" fill="#111827">$198.42</text>
  <text x="665" y="345" font-family="Arial, sans-serif" font-size="11" fill="#10b981" text-anchor="end">+0.3%</text>

  <!-- EUR/USD -->
  <rect x="300" y="378" width="125" height="70" rx="8" fill="#f8fafc" stroke="#e5e7eb" stroke-width="1"/>
  <rect x="310" y="388" width="20" height="20" rx="5" fill="#f59e0b" opacity="0.2"/>
  <text x="320" y="403" font-family="Arial, sans-serif" font-size="10" fill="#f59e0b" text-anchor="middle">€</text>
  <text x="340" y="403" font-family="Arial, sans-serif" font-size="13" fill="#111827" font-weight="bold">EUR/USD</text>
  <text x="300" y="425" font-family="Arial, sans-serif" font-size="12" fill="#111827">1.0842</text>
  <text x="395" y="425" font-family="Arial, sans-serif" font-size="11" fill="#ef4444" text-anchor="end">-0.1%</text>

  <!-- SPX -->
  <rect x="435" y="378" width="125" height="70" rx="8" fill="#f8fafc" stroke="#e5e7eb" stroke-width="1"/>
  <rect x="445" y="388" width="20" height="20" rx="5" fill="#8b5cf6" opacity="0.2"/>
  <text x="455" y="403" font-family="Arial, sans-serif" font-size="10" fill="#8b5cf6" text-anchor="middle">S</text>
  <text x="475" y="403" font-family="Arial, sans-serif" font-size="13" fill="#111827" font-weight="bold">SPX</text>
  <text x="435" y="425" font-family="Arial, sans-serif" font-size="12" fill="#111827">5,432</text>
  <text x="530" y="425" font-family="Arial, sans-serif" font-size="11" fill="#10b981" text-anchor="end">+0.5%</text>

  <!-- Add symbol button -->
  <rect x="570" y="378" width="125" height="70" rx="8" fill="#f0fdf4" stroke="#10b981" stroke-width="1" stroke-dasharray="4"/>
  <text x="632" y="420" font-family="Arial, sans-serif" font-size="13" fill="#10b981" text-anchor="middle" font-weight="bold">+ Add</text>

  <!-- Trade Journal -->
  <rect x="740" y="260" width="440" height="320" rx="10" fill="#ffffff" filter="url(#shadow2)"/>
  <text x="760" y="285" font-family="Arial, sans-serif" font-size="16" fill="#111827" font-weight="bold">Trade Journal</text>
  <rect x="760" y="298" width="400" height="1" fill="#e5e7eb"/>

  <g font-family="Arial, sans-serif" font-size="10" fill="#6b7280">
    <text x="760" y="312">Symbol</text>
    <text x="810" y="312">Dir</text>
    <text x="850" y="312">Entry</text>
    <text x="900" y="312">Exit</text>
    <text x="950" y="312">Size</text>
    <text x="1000" y="312">P&amp;L</text>
    <text x="1060" y="312">Status</text>
    <text x="1130" y="312">Action</text>
  </g>

  <!-- Trade rows -->
  <rect x="760" y="318" width="400" height="1" fill="#f3f4f6"/>
  <text x="760" y="335" font-family="Arial, sans-serif" font-size="12" fill="#111827" font-weight="bold">BTC</text>
  <text x="810" y="335" font-family="Arial, sans-serif" font-size="11" fill="#10b981">Long</text>
  <text x="845" y="335" font-family="Arial, sans-serif" font-size="11" fill="#111827">$56.2k</text>
  <text x="895" y="335" font-family="Arial, sans-serif" font-size="11" fill="#111827">$58.4k</text>
  <text x="945" y="335" font-family="Arial, sans-serif" font-size="11" fill="#111827">0.5</text>
  <text x="1000" y="335" font-family="Arial, sans-serif" font-size="11" fill="#10b981" font-weight="bold">+€1,100</text>
  <rect x="1055" y="325" width="38" height="16" rx="8" fill="#d1fae5"/>
  <text x="1074" y="337" font-family="Arial, sans-serif" font-size="9" fill="#10b981" text-anchor="middle">Open</text>
  <text x="1130" y="335" font-family="Arial, sans-serif" font-size="10" fill="#3b82f6">Edit</text>

  <rect x="760" y="348" width="400" height="1" fill="#f3f4f6"/>
  <text x="760" y="365" font-family="Arial, sans-serif" font-size="12" fill="#111827" font-weight="bold">ETH</text>
  <text x="810" y="365" font-family="Arial, sans-serif" font-size="11" fill="#ef4444">Short</text>
  <text x="845" y="365" font-family="Arial, sans-serif" font-size="11" fill="#111827">$3.2k</text>
  <text x="895" y="365" font-family="Arial, sans-serif" font-size="11" fill="#111827">$3.1k</text>
  <text x="945" y="365" font-family="Arial, sans-serif" font-size="11" fill="#111827">2.0</text>
  <text x="1000" y="365" font-family="Arial, sans-serif" font-size="11" fill="#10b981" font-weight="bold">+€210</text>
  <rect x="1055" y="355" width="38" height="16" rx="8" fill="#f3f4f6"/>
  <text x="1074" y="367" font-family="Arial, sans-serif" font-size="9" fill="#6b7280" text-anchor="middle">Closed</text>
  <text x="1130" y="365" font-family="Arial, sans-serif" font-size="10" fill="#3b82f6">Edit</text>

  <rect x="760" y="378" width="400" height="1" fill="#f3f4f6"/>
  <text x="760" y="395" font-family="Arial, sans-serif" font-size="12" fill="#111827" font-weight="bold">AAPL</text>
  <text x="810" y="395" font-family="Arial, sans-serif" font-size="11" fill="#10b981">Long</text>
  <text x="845" y="395" font-family="Arial, sans-serif" font-size="11" fill="#111827">$195</text>
  <text x="895" y="395" font-family="Arial, sans-serif" font-size="11" fill="#111827">—</text>
  <text x="945" y="395" font-family="Arial, sans-serif" font-size="11" fill="#111827">50</text>
  <text x="1000" y="395" font-family="Arial, sans-serif" font-size="11" fill="#10b981" font-weight="bold">+€172</text>
  <rect x="1055" y="385" width="38" height="16" rx="8" fill="#d1fae5"/>
  <text x="1074" y="397" font-family="Arial, sans-serif" font-size="9" fill="#10b981" text-anchor="middle">Open</text>
  <text x="1130" y="395" font-family="Arial, sans-serif" font-size="10" fill="#3b82f6">Edit</text>

  <rect x="760" y="408" width="400" height="1" fill="#f3f4f6"/>
  <text x="760" y="425" font-family="Arial, sans-serif" font-size="12" fill="#111827" font-weight="bold">SPX</text>
  <text x="810" y="425" font-family="Arial, sans-serif" font-size="11" fill="#10b981">Long</text>
  <text x="845" y="425" font-family="Arial, sans-serif" font-size="11" fill="#111827">5,240</text>
  <text x="895" y="425" font-family="Arial, sans-serif" font-size="11" fill="#111827">5,432</text>
  <text x="945" y="425" font-family="Arial, sans-serif" font-size="11" fill="#111827">1</text>
  <text x="1000" y="425" font-family="Arial, sans-serif" font-size="11" fill="#10b981" font-weight="bold">+€1,938</text>
  <rect x="1055" y="415" width="38" height="16" rx="8" fill="#f3f4f6"/>
  <text x="1074" y="427" font-family="Arial, sans-serif" font-size="9" fill="#6b7280" text-anchor="middle">Closed</text>
  <text x="1130" y="425" font-family="Arial, sans-serif" font-size="10" fill="#3b82f6">Edit</text>

  <rect x="760" y="438" width="400" height="1" fill="#f3f4f6"/>
  <text x="760" y="455" font-family="Arial, sans-serif" font-size="12" fill="#111827" font-weight="bold">EUR/USD</text>
  <text x="810" y="455" font-family="Arial, sans-serif" font-size="11" fill="#ef4444">Short</text>
  <text x="845" y="455" font-family="Arial, sans-serif" font-size="11" fill="#111827">1.09</text>
  <text x="895" y="455" font-family="Arial, sans-serif" font-size="11" fill="#111827">1.08</text>
  <text x="945" y="455" font-family="Arial, sans-serif" font-size="11" fill="#111827">10k</text>
  <text x="1000" y="455" font-family="Arial, sans-serif" font-size="11" fill="#ef4444" font-weight="bold">-€450</text>
  <rect x="1055" y="445" width="38" height="16" rx="8" fill="#f3f4f6"/>
