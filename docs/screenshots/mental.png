<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="800" viewBox="0 0 1200 800">
  <defs>
    <filter id="shadow1"><feDropShadow dx="0" dy="1" stdDeviation="2" flood-opacity="0.05"/></filter>
    <filter id="shadow2"><feDropShadow dx="0" dy="2" stdDeviation="4" flood-opacity="0.08"/></filter>
    <linearGradient id="moodGrad" x1="0" y1="0" x2="1" y2="0"><stop offset="0%" stop-color="#f59e0b"/><stop offset="100%" stop-color="#10b981"/></linearGradient>
    <linearGradient id="energyGrad" x1="0" y1="0" x2="1" y2="0"><stop offset="0%" stop-color="#f59e0b"/><stop offset="100%" stop-color="#3b82f6"/></linearGradient>
    <linearGradient id="stressGrad" x1="0" y1="0" x2="1" y2="0"><stop offset="0%" stop-color="#ef4444"/><stop offset="100%" stop-color="#f59e0b"/></linearGradient>
    <linearGradient id="sleepGrad" x1="0" y1="0" x2="1" y2="0"><stop offset="0%" stop-color="#3b82f6"/><stop offset="100%" stop-color="#8b5cf6"/></linearGradient>
    <linearGradient id="medGrad" x1="0" y1="0" x2="1" y2="0"><stop offset="0%" stop-color="#8b5cf6"/><stop offset="100%" stop-color="#ec4899"/></linearGradient>
  </defs>

  <rect width="1200" height="800" fill="#f1f5f9"/>

  <!-- Browser Chrome -->
  <rect x="0" y="0" width="1200" height="36" fill="#e2e8f0"/>
  <rect x="0" y="36" width="1200" height="1" fill="#cbd5e1"/>
  <circle cx="16" cy="18" r="5" fill="#ef4444"/>
  <circle cx="30" cy="18" r="5" fill="#f59e0b"/>
  <circle cx="44" cy="18" r="5" fill="#10b981"/>
  <rect x="120" y="10" width="300" height="16" rx="8" fill="#cbd5e1"/>
  <text x="270" y="22" font-family="Arial, sans-serif" font-size="9" fill="#64748b" text-anchor="middle">localhost:3000/mental</text>

  <!-- Sidebar -->
  <rect x="0" y="37" width="256" height="763" fill="#1a1a2e"/>
  <circle cx="128" cy="85" r="28" fill="#e94560" opacity="0.15"/>
  <circle cx="128" cy="85" r="24" fill="#1a1a2e" stroke="#e94560" stroke-width="2"/>
  <text x="128" y="91" font-family="Arial, sans-serif" font-size="18" fill="#e94560" text-anchor="middle" font-weight="bold">RS</text>
  <text x="128" y="130" font-family="Arial, sans-serif" font-size="14" fill="#ffffff" text-anchor="middle" font-weight="bold">Remco Stroop</text>
  <text x="128" y="148" font-family="Arial, sans-serif" font-size="9" fill="#e94560" text-anchor="middle" letter-spacing="1">PROGRESS TO SUCCESS</text>
  <line x1="40" y1="160" x2="216" y2="160" stroke="#ffffff" stroke-opacity="0.08"/>

  <g font-family="Arial, sans-serif" font-size="13" fill="#a0aec0">
    <text x="48" y="201">Dashboard</text>
    <text x="48" y="247">Daily Log</text>
    <text x="48" y="293">Life in Weeks</text>
    <text x="48" y="339">Finances</text>
    <text x="48" y="385">Trading</text>
    <text x="48" y="431">Business</text>
    <text x="48" y="477">Growth</text>
    <!-- Mental - Active -->
    <rect x="12" y="498" width="232" height="36" rx="6" fill="#e94560" opacity="0.15"/>
    <text x="48" y="521" fill="#e94560" font-weight="bold">Mental</text>
    <text x="48" y="567">Relationships</text>
    <text x="48" y="613">Books</text>
  </g>

  <g>
    <rect x="28" y="191" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="237" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="283" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="329" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="375" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="421" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="467" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="511" width="12" height="12" rx="3" fill="#e94560"/>
    <rect x="28" y="557" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="603" width="12" height="12" rx="3" fill="#a0aec0"/>
  </g>

  <!-- Main content -->
  <rect x="256" y="37" width="944" height="763" fill="#f8fafc"/>

  <!-- PageHeader -->
  <rect x="256" y="37" width="944" height="90" fill="#ffffff" filter="url(#shadow1)"/>
  <rect x="280" y="55" width="76" height="18" rx="9" fill="#e94560" opacity="0.1"/>
  <text x="318" y="68" font-family="Arial, sans-serif" font-size="10" fill="#e94560" text-anchor="middle" font-weight="bold">HEADSPACE</text>
  <text x="280" y="100" font-family="Arial, sans-serif" font-size="22" fill="#111827" font-weight="bold">Mental Health</text>
  <text x="280" y="118" font-family="Arial, sans-serif" font-size="13" fill="#6b7280">Track your mood, energy, sleep and overall mental well-being.</text>

  <!-- Info banner -->
  <rect x="280" y="145" width="860" height="36" rx="8" fill="#f0f9ff" stroke="#bae6fd" stroke-width="1"/>
  <text x="296" y="168" font-family="Arial, sans-serif" font-size="14" fill="#3b82f6">🧠</text>
  <text x="320" y="168" font-family="Arial, sans-serif" font-size="13" fill="#3b82f6">Your mental health matters. Track daily to spot trends and take action when needed.</text>

  <!-- Metric cards grid: 3 columns, 2 rows -->
  <!-- Card 1: Mood -->
  <rect x="280" y="200" width="275" height="170" rx="10" fill="#ffffff" filter="url(#shadow2)"/>
  <text x="296" y="225" font-family="Arial, sans-serif" font-size="14" fill="#111827" font-weight="bold">Mood</text>
  <text x="520" y="225" font-family="Arial, sans-serif" font-size="20" fill="#111827" text-anchor="end" font-weight="bold">7.5</text>
  <text x="530" y="225" font-family="Arial, sans-serif" font-size="13" fill="#6b7280">/10</text>
  <rect x="296" y="238" width="240" height="6" rx="3" fill="#e5e7eb"/>
  <rect x="296" y="238" width="180" height="6" rx="3" fill="url(#moodGrad)"/>
  <!-- Mini chart -->
  <polyline points="296,340 320,330 344,335 368,325 392,320 416,318 440,312 464,308 488,305 512,300" fill="none" stroke="#10b981" stroke-width="1.5"/>
  <polygon points="296,340 320,330 344,335 368,325 392,320 416,318 440,312 464,308 488,305 512,300 512,350 296,350" fill="#10b981" opacity="0.06"/>

  <!-- Card 2: Energy -->
  <rect x="572" y="200" width="275" height="170" rx="10" fill="#ffffff" filter="url(#shadow2)"/>
  <text x="588" y="225" font-family="Arial, sans-serif" font-size="14" fill="#111827" font-weight="bold">Energy</text>
  <text x="812" y="225" font-family="Arial, sans-serif" font-size="20" fill="#111827" text-anchor="end" font-weight="bold">6.8</text>
  <text x="822" y="225" font-family="Arial, sans-serif" font-size="13" fill="#6b7280">/10</text>
  <rect x="588" y="238" width="240" height="6" rx="3" fill="#e5e7eb"/>
  <rect x="588" y="238" width="163" height="6" rx="3" fill="url(#energyGrad)"/>
  <polyline points="588,340 612,335 636,330 660,325 684,320 708,318 732,315 756,310 780,308 804,305" fill="none" stroke="#3b82f6" stroke-width="1.5"/>
  <polygon points="588,340 612,335 636,330 660,325 684,320 708,318 732,315 756,310 780,308 804,305 804,350 588,350" fill="#3b82f6" opacity="0.06"/>

  <!-- Card 3: Stress -->
  <rect x="864" y="200" width="275" height="170" rx="10" fill="#ffffff" filter="url(#shadow2)"/>
  <text x="880" y="225" font-family="Arial, sans-serif" font-size="14" fill="#111827" font-weight="bold">Stress</text>
  <text x="1104" y="225" font-family="Arial, sans-serif" font-size="20" fill="#111827" text-anchor="end" font-weight="bold">4.2</text>
  <text x="1114" y="225" font-family="Arial, sans-serif" font-size="13" fill="#6b7280">/10</text>
  <text x="1108" y="238" font-family="Arial, sans-serif" font-size="10" fill="#f59e0b" text-anchor="end">Inverted</text>
  <rect x="880" y="248" width="240" height="6" rx="3" fill="#e5e7eb"/>
  <rect x="880" y="248" width="240" height="6" rx="3" fill="url(#stressGrad)"/>
  <polyline points="880,350 904,355 928,352 952,358 976,360 1000,362 1024,358 1048,355 1072,352 1096,348" fill="none" stroke="#f59e0b" stroke-width="1.5"/>
  <polygon points="880,350 904,355 928,352 952,358 976,360 1000,362 1024,358 1048,355 1072,352 1096,348 1096,360 880,360" fill="#f59e0b" opacity="0.06"/>

  <!-- Card 4: Sleep -->
  <rect x="280" y="390" width="275" height="170" rx="10" fill="#ffffff" filter="url(#shadow2)"/>
  <text x="296" y="415" font-family="Arial, sans-serif" font-size="14" fill="#111827" font-weight="bold">Sleep</text>
  <text x="520" y="415" font-family="Arial, sans-serif" font-size="20" fill="#111827" text-anchor="end" font-weight="bold">7.2</text>
  <text x="530" y="415" font-family="Arial, sans-serif" font-size="13" fill="#6b7280">h</text>
  <rect x="296" y="428" width="240" height="6" rx="3" fill="#e5e7eb"/>
  <rect x="296" y="428" width="200" height="6" rx="3" fill="url(#sleepGrad)"/>
  <polyline points="296,530 320,525 344,528 368,522 392,518 416,520 440,515 464,510 488,508 512,505" fill="none" stroke="#8b5cf6" stroke-width="1.5"/>
  <polygon points="296,530 320,525 344,528 368,522 392,518 416,520 440,515 464,510 488,508 512,505 512,540 296,540" fill="#8b5cf6" opacity="0.06"/>

  <!-- Card 5: Meditation -->
  <rect x="572" y="390" width="275" height="170" rx="10" fill="#ffffff" filter="url(#shadow2)"/>
  <text x="588" y="415" font-family="Arial, sans-serif" font-size="14" fill="#111827" font-weight="bold">Meditation</text>
  <text x="812" y="415" font-family="Arial, sans-serif" font-size="20" fill="#111827" text-anchor="end" font-weight="bold">12</text>
  <text x="822" y="415" font-family="Arial, sans-serif" font-size="13" fill="#6b7280">min</text>
  <rect x="588" y="428" width="240" height="6" rx="3" fill="#e5e7eb"/>
  <rect x="588" y="428" width="180" height="6" rx="3" fill="url(#medGrad)"/>
  <polyline points="588,530 612,528 636,525 660,522 684,518 708,515 732,510 756,508 780,505 804,500" fill="none" stroke="#ec4899" stroke-width="1.5"/>
  <polygon points="588,530 612,528 636,525 660,522 684,518 708,515 732,510 756,508 780,505 804,500 804,540 588,540" fill="#ec4899" opacity="0.06"/>

  <!-- Add a note/placeholder for card 6 -->
  <rect x="864" y="390" width="275" height="170" rx="10" fill="#ffffff" filter="url(#shadow2)"/>
  <text x="880" y="415" font-family="Arial, sans-serif" font-size="14" fill="#111827" font-weight="bold">Journal Streak</text>
  <text x="1104" y="415" font-family="Arial, sans-serif" font-size="20" fill="#111827" text-anchor="end" font-weight="bold">8d</text>
  <rect x="880" y="428" width="240" height="6" rx="3" fill="#e5e7eb"/>
  <rect x="880" y="428" width="220" height="6" rx="3" fill="url(#moodGrad)"/>
  <text x="880" y="465" font-family="Arial, sans-serif" font-size="12" fill="#6b7280">Consecutive days journaling</text>
  <text x="1100" y="465" font-family="Arial, sans-serif" font-size="12" fill="#111827" text-anchor="end" font-weight="bold">8 / 30</text>
  <polyline points="880,540 904,535 928,532 952,528 976,525 1000,522 1024,518 1048,515 1072,510 1096,508" fill="none" stroke="#10b981" stroke-width="1.5"/>
  <polygon points="880,540 904,535 928,532 952,528 976,525 1000,522 1024,518 1048,515 1072,510 1096,508 1096,550 880,550" fill="#10b981" opacity="0.06"/>
</svg>