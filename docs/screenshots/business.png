<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="800" viewBox="0 0 1200 800">
  <defs>
    <filter id="shadow1"><feDropShadow dx="0" dy="1" stdDeviation="2" flood-opacity="0.05"/></filter>
    <filter id="shadow2"><feDropShadow dx="0" dy="2" stdDeviation="4" flood-opacity="0.08"/></filter>
  </defs>

  <rect width="1200" height="800" fill="#f1f5f9"/>

  <!-- Browser Chrome -->
  <rect x="0" y="0" width="1200" height="36" fill="#e2e8f0"/>
  <rect x="0" y="36" width="1200" height="1" fill="#cbd5e1"/>
  <circle cx="16" cy="18" r="5" fill="#ef4444"/>
  <circle cx="30" cy="18" r="5" fill="#f59e0b"/>
  <circle cx="44" cy="18" r="5" fill="#10b981"/>
  <rect x="120" y="10" width="300" height="16" rx="8" fill="#cbd5e1"/>
  <text x="270" y="22" font-family="Arial, sans-serif" font-size="9" fill="#64748b" text-anchor="middle">localhost:3000/business</text>

  <!-- Sidebar -->
  <rect x="0" y="37" width="256" height="763" fill="#1a1a2e"/>
  <circle cx="128" cy="85" r="28" fill="#e94560" opacity="0.15"/>
  <circle cx="128" cy="85" r="24" fill="#1a1a2e" stroke="#e94560" stroke-width="2"/>
  <text x="128" y="91" font-family="Arial, sans-serif" font-size="18" fill="#e94560" text-anchor="middle" font-weight="bold">RS</text>
  <text x="128" y="130" font-family="Arial, sans-serif" font-size="14" fill="#ffffff" text-anchor="middle" font-weight="bold">Remco Stroop</text>
  <text x="128" y="148" font-family="Arial, sans-serif" font-size="9" fill="#e94560" text-anchor="middle" letter-spacing="1">PROGRESS TO SUCCESS</text>
  <line x1="40" y1="160" x2="216" y2="160" stroke="#ffffff" stroke-opacity="0.08"/>

  <g font-family="Arial, sans-serif" font-size="13" fill="#a0aec0">
    <text x="48" y="201">Dashboard</text>
    <text x="48" y="247">Daily Log</text>
    <text x="48" y="293">Life in Weeks</text>
    <text x="48" y="339">Finances</text>
    <text x="48" y="385">Trading</text>
    <!-- Business - Active -->
    <rect x="12" y="406" width="232" height="36" rx="6" fill="#e94560" opacity="0.15"/>
    <text x="48" y="429" fill="#e94560" font-weight="bold">Business</text>
    <text x="48" y="475">Growth</text>
    <text x="48" y="521">Mental</text>
    <text x="48" y="567">Relationships</text>
    <text x="48" y="613">Books</text>
  </g>

  <g>
    <rect x="28" y="191" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="237" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="283" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="329" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="375" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="419" width="12" height="12" rx="3" fill="#e94560"/>
    <rect x="28" y="465" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="511" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="557" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="603" width="12" height="12" rx="3" fill="#a0aec0"/>
  </g>

  <!-- Main content -->
  <rect x="256" y="37" width="944" height="763" fill="#f8fafc"/>

  <!-- PageHeader -->
  <rect x="256" y="37" width="944" height="90" fill="#ffffff" filter="url(#shadow1)"/>
  <rect x="280" y="55" width="68" height="18" rx="9" fill="#e94560" opacity="0.1"/>
  <text x="314" y="68" font-family="Arial, sans-serif" font-size="10" fill="#e94560" text-anchor="middle" font-weight="bold">VENTURES</text>
  <text x="280" y="100" font-family="Arial, sans-serif" font-size="22" fill="#111827" font-weight="bold">Business Tracker</text>
  <text x="280" y="118" font-family="Arial, sans-serif" font-size="13" fill="#6b7280">Track revenue, costs and profit across all your ventures.</text>

  <!-- 3 Summary Cards -->
  <rect x="280" y="155" width="275" height="80" rx="10" fill="#ffffff" filter="url(#shadow2)"/>
  <text x="300" y="178" font-family="Arial, sans-serif" font-size="12" fill="#6b7280">Monthly Revenue</text>
  <text x="300" y="210" font-family="Arial, sans-serif" font-size="22" fill="#10b981" font-weight="bold">€5,400</text>

  <rect x="570" y="155" width="275" height="80" rx="10" fill="#ffffff" filter="url(#shadow2)"/>
  <text x="590" y="178" font-family="Arial, sans-serif" font-size="12" fill="#6b7280">Monthly Costs</text>
  <text x="590" y="210" font-family="Arial, sans-serif" font-size="22" fill="#ef4444" font-weight="bold">€2,800</text>

  <rect x="860" y="155" width="275" height="80" rx="10" fill="#ffffff" filter="url(#shadow2)"/>
  <text x="880" y="178" font-family="Arial, sans-serif" font-size="12" fill="#6b7280">Monthly Profit</text>
  <text x="880" y="210" font-family="Arial, sans-serif" font-size="22" fill="#10b981" font-weight="bold">€2,600</text>

  <!-- Ventures section -->
  <rect x="280" y="260" width="860" height="280" rx="10" fill="#ffffff" filter="url(#shadow2)"/>
  <text x="300" y="285" font-family="Arial, sans-serif" font-size="16" fill="#111827" font-weight="bold">Ventures</text>

  <!-- Venture 1 -->
  <rect x="300" y="300" width="390" height="200" rx="8" fill="#f8fafc" stroke="#e5e7eb" stroke-width="1"/>
  <text x="316" y="325" font-family="Arial, sans-serif" font-size="15" fill="#111827" font-weight="bold">Freelance Web Dev</text>
  <rect x="316" y="336" width="50" height="18" rx="9" fill="#d1fae5"/>
  <text x="341" y="349" font-family="Arial, sans-serif" font-size="9" fill="#10b981" text-anchor="middle" font-weight="bold">Active</text>

  <rect x="316" y="365" width="358" height="1" fill="#e5e7eb"/>
  <g font-family="Arial, sans-serif" font-size="12">
    <text x="316" y="382" fill="#6b7280">Revenue</text>
    <text x="674" y="382" fill="#10b981" text-anchor="end" font-weight="bold">€3,200 /mo</text>
    <text x="316" y="402" fill="#6b7280">Costs</text>
    <text x="674" y="402" fill="#ef4444" text-anchor="end" font-weight="bold">€800 /mo</text>
    <text x="316" y="422" fill="#6b7280">Profit</text>
    <text x="674" y="422" fill="#10b981" text-anchor="end" font-weight="bold">€2,400 /mo</text>
  </g>
  <rect x="316" y="435" width="358" height="1" fill="#e5e7eb"/>
  <text x="316" y="455" font-family="Arial, sans-serif" font-size="11" fill="#6b7280">📝 Full-stack development for various clients. Steady monthly income.</text>
  <rect x="600" y="470" width="80" height="22" rx="4" fill="#f3f4f6"/>
  <text x="640" y="485" font-family="Arial, sans-serif" font-size="10" fill="#6b7280" text-anchor="middle">Delete</text>

  <!-- Venture 2 -->
  <rect x="710" y="300" width="410" height="200" rx="8" fill="#f8fafc" stroke="#e5e7eb" stroke-width="1"/>
  <text x="726" y="325" font-family="Arial, sans-serif" font-size="15" fill="#111827" font-weight="bold">SaaS Side Project</text>
  <rect x="726" y="336" width="52" height="18" rx="9" fill="#fee7a0"/>
  <text x="752" y="349" font-family="Arial, sans-serif" font-size="9" fill="#f59e0b" text-anchor="middle" font-weight="bold">Paused</text>

  <rect x="726" y="365" width="378" height="1" fill="#e5e7eb"/>
  <g font-family="Arial, sans-serif" font-size="12">
    <text x="726" y="382" fill="#6b7280">Revenue</text>
    <text x="1084" y="382" fill="#10b981" text-anchor="end" font-weight="bold">€1,200 /mo</text>
    <text x="726" y="402" fill="#6b7280">Costs</text>
    <text x="1084" y="402" fill="#ef4444" text-anchor="end" font-weight="bold">€1,500 /mo</text>
    <text x="726" y="422" fill="#6b7280">Profit</text>
    <text x="1084" y="422" fill="#ef4444" text-anchor="end" font-weight="bold">-€300 /mo</text>
  </g>
  <rect x="726" y="435" width="378" height="1" fill="#e5e7eb"/>
  <text x="726" y="455" font-family="Arial, sans-serif" font-size="11" fill="#6b7280">📝 MVP built but needs more traction. Temporarily paused for refocus.</text>
  <rect x="1020" y="470" width="80" height="22" rx="4" fill="#f3f4f6"/>
  <text x="1060" y="485" font-family="Arial, sans-serif" font-size="10" fill="#6b7280" text-anchor="middle">Delete</text>

  <!-- Add venture button -->
  <rect x="300" y="555" width="140" height="34" rx="8" fill="#f0fdf4" stroke="#10b981" stroke-width="1"/>
  <text x="370" y="577" font-family="Arial, sans-serif" font-size="13" fill="#10b981" text-anchor="middle" font-weight="bold">+ Add venture</text>
</svg>