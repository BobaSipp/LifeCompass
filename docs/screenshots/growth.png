<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="800" viewBox="0 0 1200 800">
  <defs>
    <filter id="shadow1"><feDropShadow dx="0" dy="1" stdDeviation="2" flood-opacity="0.05"/></filter>
    <filter id="shadow2"><feDropShadow dx="0" dy="2" stdDeviation="4" flood-opacity="0.08"/></filter>
  </defs>

  <rect width="1200" height="800" fill="#f1f5f9"/>

  <!-- Browser Chrome -->
  <rect x="0" y="0" width="1200" height="36" fill="#e2e8f0"/>
  <rect x="0" y="36" width="1200" height="1" fill="#cbd5e1"/>
  <circle cx="16" cy="18" r="5" fill="#ef4444"/>
  <circle cx="30" cy="18" r="5" fill="#f59e0b"/>
  <circle cx="44" cy="18" r="5" fill="#10b981"/>
  <rect x="120" y="10" width="300" height="16" rx="8" fill="#cbd5e1"/>
  <text x="270" y="22" font-family="Arial, sans-serif" font-size="9" fill="#64748b" text-anchor="middle">localhost:3000/growth</text>

  <!-- Sidebar -->
  <rect x="0" y="37" width="256" height="763" fill="#1a1a2e"/>
  <circle cx="128" cy="85" r="28" fill="#e94560" opacity="0.15"/>
  <circle cx="128" cy="85" r="24" fill="#1a1a2e" stroke="#e94560" stroke-width="2"/>
  <text x="128" y="91" font-family="Arial, sans-serif" font-size="18" fill="#e94560" text-anchor="middle" font-weight="bold">RS</text>
  <text x="128" y="130" font-family="Arial, sans-serif" font-size="14" fill="#ffffff" text-anchor="middle" font-weight="bold">Remco Stroop</text>
  <text x="128" y="148" font-family="Arial, sans-serif" font-size="9" fill="#e94560" text-anchor="middle" letter-spacing="1">PROGRESS TO SUCCESS</text>
  <line x1="40" y1="160" x2="216" y2="160" stroke="#ffffff" stroke-opacity="0.08"/>

  <g font-family="Arial, sans-serif" font-size="13" fill="#a0aec0">
    <text x="48" y="201">Dashboard</text>
    <text x="48" y="247">Daily Log</text>
    <text x="48" y="293">Life in Weeks</text>
    <text x="48" y="339">Finances</text>
    <text x="48" y="385">Trading</text>
    <text x="48" y="431">Business</text>
    <!-- Growth - Active -->
    <rect x="12" y="452" width="232" height="36" rx="6" fill="#e94560" opacity="0.15"/>
    <text x="48" y="475" fill="#e94560" font-weight="bold">Growth</text>
    <text x="48" y="521">Mental</text>
    <text x="48" y="567">Relationships</text>
    <text x="48" y="613">Books</text>
  </g>

  <g>
    <rect x="28" y="191" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="237" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="283" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="329" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="375" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="421" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="465" width="12" height="12" rx="3" fill="#e94560"/>
    <rect x="28" y="511" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="557" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="603" width="12" height="12" rx="3" fill="#a0aec0"/>
  </g>

  <!-- Main content -->
  <rect x="256" y="37" width="944" height="763" fill="#f8fafc"/>

  <!-- PageHeader -->
  <rect x="256" y="37" width="944" height="90" fill="#ffffff" filter="url(#shadow1)"/>
  <rect x="280" y="55" width="96" height="18" rx="9" fill="#e94560" opacity="0.1"/>
  <text x="328" y="68" font-family="Arial, sans-serif" font-size="10" fill="#e94560" text-anchor="middle" font-weight="bold">COMPOUNDING</text>
  <text x="280" y="100" font-family="Arial, sans-serif" font-size="22" fill="#111827" font-weight="bold">Growth</text>
  <text x="280" y="118" font-family="Arial, sans-serif" font-size="13" fill="#6b7280">Track your progress across all areas — gym, finances, and mind.</text>

  <!-- Snapshot button -->
  <rect x="1040" y="68" width="140" height="28" rx="6" fill="#f8fafc" stroke="#e5e7eb" stroke-width="1"/>
  <text x="1110" y="87" font-family="Arial, sans-serif" font-size="12" fill="#6b7280" text-anchor="middle">📸 Snapshot net worth</text>

  <!-- Gym Progress section -->
  <rect x="280" y="155" width="440" height="280" rx="10" fill="#ffffff" filter="url(#shadow2)"/>
  <text x="300" y="180" font-family="Arial, sans-serif" font-size="16" fill="#111827" font-weight="bold">Gym Progress</text>

  <!-- Metric 1: Bench Press -->
  <rect x="300" y="195" width="400" height="70" rx="8" fill="#f8fafc" stroke="#e5e7eb" stroke-width="1"/>
  <text x="316" y="216" font-family="Arial, sans-serif" font-size="13" fill="#111827" font-weight="bold">Bench Press</text>
  <text x="316" y="240" font-family="Arial, sans-serif" font-size="20" fill="#111827" font-weight="bold">85kg</text>
  <text x="380" y="240" font-family="Arial, sans-serif" font-size="12" fill="#10b981">+5kg</text>
  <!-- Mini line chart -->
  <polyline points="580,240 600,235 620,225 640,218 660,210 680,208" fill="none" stroke="#3b82f6" stroke-width="2"/>
  <polygon points="580,240 600,235 620,225 640,218 660,210 680,208 680,250 580,250" fill="#3b82f6" opacity="0.08"/>

  <!-- Metric 2: Squat -->
  <rect x="300" y="275" width="400" height="70" rx="8" fill="#f8fafc" stroke="#e5e7eb" stroke-width="1"/>
  <text x="316" y="296" font-family="Arial, sans-serif" font-size="13" fill="#111827" font-weight="bold">Squat</text>
  <text x="316" y="320" font-family="Arial, sans-serif" font-size="20" fill="#111827" font-weight="bold">120kg</text>
  <text x="380" y="320" font-family="Arial, sans-serif" font-size="12" fill="#10b981">+8kg</text>
  <polyline points="580,320 600,315 620,308 640,300 660,292 680,285" fill="none" stroke="#3b82f6" stroke-width="2"/>
  <polygon points="580,320 600,315 620,308 640,300 660,292 680,285 680,330 580,330" fill="#3b82f6" opacity="0.08"/>

  <!-- Metric 3: Body Weight -->
  <rect x="300" y="355" width="400" height="70" rx="8" fill="#f8fafc" stroke="#e5e7eb" stroke-width="1"/>
  <text x="316" y="376" font-family="Arial, sans-serif" font-size="13" fill="#111827" font-weight="bold">Body Weight</text>
  <text x="316" y="400" font-family="Arial, sans-serif" font-size="20" fill="#111827" font-weight="bold">78kg</text>
  <text x="380" y="400" font-family="Arial, sans-serif" font-size="12" fill="#f59e0b">-1kg</text>
  <polyline points="580,400 600,398 620,395 640,396 660,392 680,390" fill="none" stroke="#f59e0b" stroke-width="2"/>
  <polygon points="580,400 600,398 620,395 640,396 660,392 680,390 680,410 580,410" fill="#f59e0b" opacity="0.08"/>

  <!-- Finance Progress section -->
  <rect x="740" y="155" width="440" height="160" rx="10" fill="#ffffff" filter="url(#shadow2)"/>
  <text x="760" y="180" font-family="Arial, sans-serif" font-size="16" fill="#111827" font-weight="bold">Finance Progress</text>
  <text x="760" y="200" font-family="Arial, sans-serif" font-size="20" fill="#111827" font-weight="bold">€38k</text>
  <text x="820" y="200" font-family="Arial, sans-serif" font-size="12" fill="#10b981">Net Worth</text>
  <!-- Line chart for net worth -->
  <polyline points="760,280 790,270 820,265 850,250 880,240 910,235 940,225 970,220 1000,215 1030,210 1060,205 1090,200 1120,195 1150,190" fill="none" stroke="#10b981" stroke-width="2"/>
  <polygon points="760,280 790,270 820,265 850,250 880,240 910,235 940,225 970,220 1000,215 1030,210 1060,205 1090,200 1120,195 1150,190 1150,290 760,290" fill="#10b981" opacity="0.06"/>

  <!-- Mind & IQ section -->
  <rect x="740" y="330" width="440" height="160" rx="10" fill="#ffffff" filter="url(#shadow2)"/>
  <text x="760" y="355" font-family="Arial, sans-serif" font-size="16" fill="#111827" font-weight="bold">Mind &amp; IQ</text>
  <text x="760" y="375" font-family="Arial, sans-serif" font-size="20" fill="#111827" font-weight="bold">Focus Score</text>

  <!-- Progress bar for focus score -->
  <rect x="760" y="395" width="400" height="10" rx="5" fill="#e5e7eb"/>
  <rect x="760" y="395" width="300" height="10" rx="5" fill="url(#blueGrad)"/>
  <defs><linearGradient id="blueGrad" x1="0" y1="0" x2="1" y2="0"><stop offset="0%" stop-color="#3b82f6"/><stop offset="100%" stop-color="#60a5fa"/></linearGradient></defs>

  <text x="760" y="430" font-family="Arial, sans-serif" font-size="13" fill="#6b7280">75% — Good concentration levels</text>
  <text x="1160" y="430" font-family="Arial, sans-serif" font-size="13" fill="#111827" text-anchor="end" font-weight="bold">75%</text>

  <!-- Mini sparkline -->
  <polyline points="760,465 790,460 820,462 850,458 880,455 910,450 940,448 970,445 1000,442 1030,440 1060,438 1090,435 1120,432 1150,430" fill="none" stroke="#3b82f6" stroke-width="1.5"/>
  <polygon points="760,465 790,460 820,462 850,458 880,455 910,450 940,448 970,445 1000,442 1030,440 1060,438 1090,435 1120,432 1150,430 1150,470 760,470" fill="#3b82f6" opacity="0.05"/>
</svg>