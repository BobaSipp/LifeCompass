<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="800" viewBox="0 0 1200 800">
  <defs>
    <filter id="shadow1"><feDropShadow dx="0" dy="1" stdDeviation="2" flood-opacity="0.05"/></filter>
    <filter id="shadow2"><feDropShadow dx="0" dy="2" stdDeviation="4" flood-opacity="0.08"/></filter>
    <linearGradient id="barActive" x1="0" y1="0" x2="1" y2="0"><stop offset="0%" stop-color="#e94560"/><stop offset="100%" stop-color="#ff6b6b"/></linearGradient>
    <linearGradient id="progressGreen" x1="0" y1="0" x2="1" y2="0"><stop offset="0%" stop-color="#10b981"/><stop offset="100%" stop-color="#4ecca3"/></linearGradient>
    <linearGradient id="progressAmber" x1="0" y1="0" x2="1" y2="0"><stop offset="0%" stop-color="#f59e0b"/><stop offset="100%" stop-color="#fbbf24"/></linearGradient>
    <linearGradient id="progressBlue" x1="0" y1="0" x2="1" y2="0"><stop offset="0%" stop-color="#3b82f6"/><stop offset="100%" stop-color="#60a5fa"/></linearGradient>
  </defs>

  <!-- Background -->
  <rect width="1200" height="800" fill="#f1f5f9"/>

  <!-- Browser Chrome -->
  <rect x="0" y="0" width="1200" height="36" fill="#e2e8f0"/>
  <rect x="0" y="36" width="1200" height="1" fill="#cbd5e1"/>
  <circle cx="16" cy="18" r="5" fill="#ef4444"/>
  <circle cx="30" cy="18" r="5" fill="#f59e0b"/>
  <circle cx="44" cy="18" r="5" fill="#10b981"/>
  <rect x="120" y="10" width="300" height="16" rx="8" fill="#cbd5e1"/>
  <text x="270" y="22" font-family="Arial, sans-serif" font-size="9" fill="#64748b" text-anchor="middle">localhost:3000/dashboard</text>

  <!-- Sidebar -->
  <rect x="0" y="37" width="256" height="763" fill="#1a1a2e"/>

  <!-- Sidebar header - Profile -->
  <circle cx="128" cy="85" r="28" fill="#e94560" opacity="0.15"/>
  <circle cx="128" cy="85" r="24" fill="#1a1a2e" stroke="#e94560" stroke-width="2"/>
  <text x="128" y="91" font-family="Arial, sans-serif" font-size="18" fill="#e94560" text-anchor="middle" font-weight="bold">RS</text>
  <text x="128" y="130" font-family="Arial, sans-serif" font-size="14" fill="#ffffff" text-anchor="middle" font-weight="bold">Remco Stroop</text>
  <text x="128" y="148" font-family="Arial, sans-serif" font-size="9" fill="#e94560" text-anchor="middle" letter-spacing="1">PROGRESS TO SUCCESS</text>
  <line x1="40" y1="160" x2="216" y2="160" stroke="#ffffff" stroke-opacity="0.08"/>

  <!-- Nav items -->
  <g font-family="Arial, sans-serif" font-size="13" fill="#a0aec0">
    <!-- Dashboard - Active -->
    <rect x="12" y="178" width="232" height="36" rx="6" fill="#e94560" opacity="0.15"/>
    <text x="48" y="201" fill="#e94560" font-weight="bold">Dashboard</text>

    <!-- Daily Log -->
    <text x="48" y="247">Daily Log</text>

    <!-- Life in Weeks -->
    <text x="48" y="293">Life in Weeks</text>

    <!-- Finances -->
    <text x="48" y="339">Finances</text>

    <!-- Trading -->
    <text x="48" y="385">Trading</text>

    <!-- Business -->
    <text x="48" y="431">Business</text>

    <!-- Growth -->
    <text x="48" y="477">Growth</text>

    <!-- Mental -->
    <text x="48" y="523">Mental</text>

    <!-- Relationships -->
    <text x="48" y="569">Relationships</text>

    <!-- Books -->
    <text x="48" y="615">Books</text>
  </g>

  <!-- Sidebar icons (simple dots/boxes) -->
  <g fill="#a0aec0">
    <rect x="28" y="191" width="12" height="12" rx="3" fill="#e94560"/>
    <rect x="28" y="237" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="283" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="329" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="375" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="421" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="467" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="513" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="559" width="12" height="12" rx="3" fill="#a0aec0"/>
    <rect x="28" y="605" width="12" height="12" rx="3" fill="#a0aec0"/>
  </g>

  <!-- Main content -->
  <rect x="256" y="37" width="944" height="763" fill="#f8fafc"/>

  <!-- PageHeader -->
  <rect x="256" y="37" width="944" height="90" fill="#ffffff" filter="url(#shadow1)"/>
  <rect x="280" y="55" width="60" height="18" rx="9" fill="#e94560" opacity="0.1"/>
  <text x="310" y="68" font-family="Arial, sans-serif" font-size="10" fill="#e94560" text-anchor="middle" font-weight="bold">OVERVIEW</text>
  <text x="280" y="100" font-family="Arial, sans-serif" font-size="22" fill="#111827" font-weight="bold">Command Center</text>
  <text x="280" y="118" font-family="Arial, sans-serif" font-size="13" fill="#6b7280">Your life and money at a glance — track everything from one place.</text>

  <!-- Stat Cards Row 1 -->
  <!-- Card 1: Net Worth -->
  <rect x="280" y="155" width="205" height="100" rx="10" fill="#ffffff" filter="url(#shadow2)"/>
  <text x="296" y="178" font-family="Arial, sans-serif" font-size="12" fill="#6b7280">Net Worth</text>
  <text x="296" y="208" font-family="Arial, sans-serif" font-size="22" fill="#111827" font-weight="bold">€38,420</text>
  <text x="296" y="228" font-family="Arial, sans-serif" font-size="11" fill="#10b981">↑ €1,240 this month</text>
  <circle cx="455" cy="175" r="16" fill="#3b82f6" opacity="0.1"/>
  <text x="455" y="180" font-family="Arial, sans-serif" font-size="14" fill="#3b82f6" text-anchor="middle">€</text>

  <!-- Card 2: Interest -->
  <rect x="500" y="155" width="205" height="100" rx="10" fill="#ffffff" filter="url(#shadow2)"/>
  <text x="516" y="178" font-family="Arial, sans-serif" font-size="12" fill="#6b7280">Projected Interest / yr</text>
  <text x="516" y="208" font-family="Arial, sans-serif" font-size="22" fill="#111827" font-weight="bold">€1,240</text>
  <text x="516" y="228" font-family="Arial, sans-serif" font-size="11" fill="#6b7280">at 3.2% APY</text>
  <circle cx="675" cy="175" r="16" fill="#10b981" opacity="0.1"/>
  <text x="675" y="180" font-family="Arial, sans-serif" font-size="14" fill="#10b981" text-anchor="middle">%</text>

  <!-- Card 3: This Month -->
  <rect x="720" y="155" width="205" height="100" rx="10" fill="#ffffff" filter="url(#shadow2)"/>
  <text x="736" y="178" font-family="Arial, sans-serif" font-size="12" fill="#6b7280">This Month Net</text>
  <text x="736" y="208" font-family="Arial, sans-serif" font-size="22" fill="#111827" font-weight="bold">€2,150</text>
  <text x="736" y="228" font-family="Arial, sans-serif" font-size="11" fill="#10b981">€4.2k in · €2.1k out</text>
  <circle cx="895" cy="175" r="16" fill="#f59e0b" opacity="0.1"/>
  <text x="895" y="180" font-family="Arial, sans-serif" font-size="14" fill="#f59e0b" text-anchor="middle">$</text>

  <!-- Card 4: Green Streak -->
  <rect x="940" y="155" width="205" height="100" rx="10" fill="#ffffff" filter="url(#shadow2)"/>
  <text x="956" y="178" font-family="Arial, sans-serif" font-size="12" fill="#6b7280">Green Streak</text>
  <text x="956" y="208" font-family="Arial, sans-serif" font-size="22" fill="#111827" font-weight="bold">14d</text>
  <text x="956" y="228" font-family="Arial, sans-serif" font-size="11" fill="#10b981">14 perfect days</text>
  <circle cx="1115" cy="175" r="16" fill="#10b981" opacity="0.1"/>
  <text x="1115" y="180" font-family="Arial, sans-serif" font-size="14" fill="#10b981" text-anchor="middle">✓</text>

  <!-- Row 2 left: Today panel -->
  <rect x="280" y="275" width="420" height="240" rx="10" fill="#ffffff" filter="url(#shadow2)"/>
  <text x="300" y="300" font-family="Arial, sans-serif" font-size="16" fill="#111827" font-weight="bold">Today</text>
  <rect x="300" y="315" width="380" height="8" rx="4" fill="#e5e7eb"/>
  <rect x="300" y="315" width="285" height="8" rx="4" fill="url(#progressGreen)"/>
  <text x="300" y="340" font-family="Arial, sans-serif" font-size="13" fill="#6b7280">3 of 4 tasks done</text>
  <text x="660" y="340" font-family="Arial, sans-serif" font-size="13" fill="#111827" text-anchor="end" font-weight="bold">75%</text>

  <!-- Task items -->
  <rect x="300" y="360" width="14" height="14" rx="3" fill="#10b981"/>
  <text x="302" y="371" font-family="Arial, sans-serif" font-size="10" fill="#ffffff" text-anchor="middle">✓</text>
  <text x="324" y="371" font-family="Arial, sans-serif" font-size="13" fill="#6b7280" text-decoration="line-through">Morning journal & reflection</text>

  <rect x="300" y="386" width="14" height="14" rx="3" fill="#10b981"/>
  <text x="302" y="397" font-family="Arial, sans-serif" font-size="10" fill="#ffffff" text-anchor="middle">✓</text>
  <text x="324" y="397" font-family="Arial, sans-serif" font-size="13" fill="#6b7280" text-decoration="line-through">Gym workout completed</text>

  <rect x="300" y="412" width="14" height="14" rx="3" fill="#10b981"/>
  <text x="302" y="423" font-family="Arial, sans-serif" font-size="10" fill="#ffffff" text-anchor="middle">✓</text>
  <text x="324" y="423" font-family="Arial, sans-serif" font-size="13" fill="#6b7280" text-decoration="line-through">Read 20 pages</text>

  <rect x="300" y="438" width="14" height="14" rx="3" fill="#e5e7eb" stroke="#d1d5db" stroke-width="1"/>
  <text x="324" y="449" font-family="Arial, sans-serif" font-size="13" fill="#111827">Review monthly budget</text>

  <!-- Badges -->
  <rect x="300" y="468" width="110" height="22" rx="11" fill="#10b981" opacity="0.1"/>
  <text x="355" y="483" font-family="Arial, sans-serif" font-size="10" fill="#10b981" text-anchor="middle" font-weight="bold">Set before 9AM</text>
  <rect x="420" y="468" width="90" height="22" rx="11" fill="#e5e7eb"/>
  <text x="465" y="483" font-family="Arial, sans-serif" font-size="10" fill="#6b7280" text-anchor="middle">All tasks done</text>

  <!-- Row 2 right: Life Spent -->
  <rect x="720" y="275" width="420" height="240" rx="10" fill="#ffffff" filter="url(#shadow2)"/>
  <text x="740" y="300" font-family="Arial, sans-serif" font-size="16" fill="#111827" font-weight="bold">Life Spent</text>
  <text x="740" y="320" font-family="Arial, sans-serif" font-size="13" fill="#6b7280">Percentage of life lived</text>
  <text x="1100" y="320" font-family="Arial, sans-serif" font-size="24" fill="#111827" text-anchor="end" font-weight="bold">35.2%</text>

  <!-- Life bar -->
  <rect x="740" y="340" width="380" height="18" rx="9" fill="#e5e7eb"/>
  <rect x="740" y="340" width="134" height="18" rx="9" fill="url(#progressAmber)"/>

  <text x="740" y="380" font-family="Arial, sans-serif" font-size="13" fill="#6b7280">462 of 1,326 weeks lived</text>
  <text x="1120" y="380" font-family="Arial, sans-serif" font-size="13" fill="#111827" text-anchor="end" font-weight="bold">864 weeks left</text>

  <!-- Week grid mini visualization -->
  <g transform="translate(740, 400)">
    <rect x="0" y="0" width="8" height="8" rx="1" fill="#1a1a2e"/>
    <rect x="10" y="0" width="8" height="8" rx="1" fill="#1a1a2e"/>
    <rect x="20" y="0" width="8" height="8" rx="1" fill="#1a1a2e"/>
    <rect x="30" y="0" width="8" height="8" rx="1" fill="#1a1a2e"/>
    <rect x="40" y="0" width="8" height="8" rx="1" fill="#1a1a2e"/>
    <rect x="50" y="0" width="8" height="8" rx="1" fill="#f59e0b"/>
    <rect x="60" y="0" width="8" height="8" rx="1" fill="#e5e7eb"/>
    <rect x="70" y="0" width="8" height="8" rx="1" fill="#e5e7eb"/>
    <rect x="80" y="0" width="8" height="8" rx="1" fill="#e5e7eb"/>
    <rect x="90" y="0" width="8" height="8" rx="1" fill="#e5e7eb"/>
    <rect x="100" y="0" width="8" height="8" rx="1" fill="#e5e7eb"/>
    <rect x="110" y="0" width="8" height="8" rx="1" fill="#e5e7eb"/>
    <rect x="0" y="12" width="8" height="8" rx="1" fill="#e5e7eb"/>
    <rect x="10" y="12" width="8" height="8" rx="1" fill="#e5e7eb"/>
    <rect x="20" y="12" width="8" height="8" rx="1" fill="#e5e7eb"/>
    <rect x="30" y="12" width="8" height="8" rx="1" fill="#e5e7eb"/>
    <rect x="40" y="12" width="8" height="8" rx="1" fill="#e5e7eb"/>
    <rect x="50" y="12" width="8" height="8" rx="1" fill="#e5e7eb"/>
    <rect x="60" y="12" width="8" height="8" rx="1" fill="#e5e7eb"/>
    <rect x="70" y="12" width="8" height="8" rx="1" fill="#e5e7eb"/>
    <rect x="80" y="12" width="8" height="8" rx="1" fill="#e5e7eb"/>
    <rect x="90" y="12" width="8" height="8" rx="1" fill="#e5e7eb"/>
    <rect x="100" y="12" width="8" height="8" rx="1" fill="#e5e7eb"/>
    <rect x="110" y="12" width="8" height="8" rx="1" fill="#e5e7eb"/>
  </g>
</svg>